{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/admin.html",  "destination": "/admin.html" },
    { "source": "/owner.html",  "destination": "/owner.html" },

    { "source": "/admin",       "destination": "/admin.html" },
    { "source": "/admin/:path*","destination": "/admin.html" },

    { "source": "/owner",       "destination": "/owner.html" },
    { "source": "/owner/:path*","destination": "/owner.html" },

    { "source": "/r/:path*",    "destination": "/index.html" },
    { "source": "/cancel",      "destination": "/index.html" },
    { "source": "/review",      "destination": "/index.html" },

    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
